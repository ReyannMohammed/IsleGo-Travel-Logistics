<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>IsleGo Travel Booking System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/static/styles.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f4f8ff 0%, #eef6ff 100%);
            color: #17324d;
        }
        .navbar {
            background: linear-gradient(90deg, #0f4c81 0%, #2a7fbe 100%) !important;
            box-shadow: 0 4px 18px rgba(15, 76, 129, 0.2);
        }
        .hero-panel {
            background: linear-gradient(120deg, rgba(7, 41, 72, 0.8), rgba(42, 127, 190, 0.7)), url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=80') center/cover;
            border-radius: 24px;
            color: white;
            padding: 48px;
            margin-bottom: 24px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }
        .hero-panel h1 {
            font-size: 2.2rem;
            font-weight: 700;
        }
        .hero-panel p {
            font-size: 1.05rem;
            max-width: 640px;
        }
        .feature-card {
            border: none;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(15, 76, 129, 0.1);
            background: white;
        }
        .feature-card img {
            height: 180px;
            object-fit: cover;
        }
        .content-card {
            background: rgba(255,255,255,0.95);
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 8px 24px rgba(15, 76, 129, 0.08);
        }
        .badge-soft {
            background: #eaf6ff;
            color: #0f4c81;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark">
    <div class="container d-flex align-items-center">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
            <img src="/static/images/logo.svg" alt="logo" height="34" style="margin-right:10px">
            <span>IsleGo Travel & Logistics</span>
        </a>
        <div class="ms-auto">
            <a class="nav-link d-inline-block text-white me-3" href="/">Home</a>
            <a class="nav-link d-inline-block text-white me-3" href="/deals">Deals</a>
            <a class="nav-link d-inline-block text-white me-3" href="/about">About</a>
            <a class="nav-link d-inline-block text-white me-3" href="/contact">Contact</a>
            <a class="btn btn-light btn-sm" href="/bookings/new">New Booking</a>
        </div>
    </div>
</nav>
<div class="container py-4">
    <section class="hero-panel">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="badge-soft">Trusted travel concierge</span>
                <h1 class="mt-3">Plan unforgettable journeys with ease</h1>
                <p class="mt-3">From luxury escapes to business travel, IsleGo helps clients book smoothly with real-time itinerary planning and professional support.</p>
                <a href="/bookings/new" class="btn btn-light text-primary fw-bold mt-3">Create Booking</a>
            </div>
            <div class="col-lg-4 text-center">
                <div class="bg-white text-dark rounded-4 p-3 shadow-sm">
                    <h5 class="mb-2">Fast, reliable, elegant</h5>
                    <p class="mb-0 small">24/7 support for clients, operators, and travel planners.</p>
                </div>
            </div>
        </div>
    </section>
    
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="content-card p-0 overflow-hidden">
            <div class="row g-0">
                <div class="col-md-6">
                    <img class="w-100 h-100 gallery-hero" src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1200&q=80" alt="Overwater bungalows">
                </div>
                <div class="col-md-6 p-4 d-flex flex-column justify-content-center">
                    <h3 class="fw-bold">Featured: Maldives Overwater Retreat</h3>
                    <p class="text-muted">Experience crystal-clear waters, private villas, and personalized concierge services. Perfect for honeymooners and luxury travelers seeking tranquility.</p>
                    <ul>
                        <li>Private transfer by speedboat</li>
                        <li>All-inclusive gourmet dining options</li>
                        <li>Snorkeling and sunset cruises available</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="feature-card">
            <img src="https://images.unsplash.com/photo-1500375592092-40eb2168fd21?auto=format&fit=crop&w=1200&q=80" alt="Island path">
            <div class="card-body">
                <h5 class="card-title">Tropical Island Escape</h5>
                <p class="card-text text-muted">Secluded beaches, bungalow stays, and tailored activities for couples and families.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <img src="https://images.unsplash.com/photo-1516483638261-f4dbaf036963?auto=format&fit=crop&w=1200&q=80" alt="Kayaking">
            <div class="card-body">
                <h5 class="card-title">Adventure & Active Tours</h5>
                <p class="card-text text-muted">Kayaking, hiking, and curated experiences for the adventurous traveler.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-card">
            <img src="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1200&q=80" alt="Tropical beach">
            <div class="card-body">
                <h5 class="card-title">Romantic Beach Retreats</h5>
                <p class="card-text text-muted">White-sand beaches, private dinners, and bespoke honeymoon packages.</p>
            </div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h4 mb-1">Client Booking Dashboard</h2>
            <p class="text-muted mb-0">Manage reservations, clients, and travel plans in one place.</p>
        </div>
        <a href="/bookings/new" class="btn btn-success">+ New Booking</a>
    </div>

    
    <div class="alert alert-info">No bookings yet. Create your first booking to begin.</div>
    
</div>

</div>
<footer class="py-4">
    <div class="container text-center text-muted small">
        &copy; IsleGo Travel & Logistics — Professional booking management
    </div>
</footer>
</body>
</html>